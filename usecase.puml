@startuml
!pragma layout smetana
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
title Use Case Diagram — PennyTrack (Personal Expense Tracker)

actor "User" as U
actor "Notification\nService" as NS

rectangle "PennyTrack System" {
  usecase "Add Transaction" as UC1
  usecase "Assign Category" as UC2
  usecase "Manage Categories" as UC3
  usecase "Set Monthly Budget" as UC4
  usecase "View Spending Summary" as UC5
  usecase "Send Over-Budget Alert" as UC6
}

U --> UC1
U --> UC3
U --> UC4
U --> UC5

UC1 ..> UC2 : <<include>>
UC6 ..> UC1 : <<extend>>
UC6 --> NS
@enduml
